{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "mingw32-nix",
      "displayName": "MinGW32 (Nix)",
      "description": "Cross-compile for Windows with the Nix-provided MinGW32 toolchain",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "toolchainFile": "${sourceDir}/.toolchain/toolchain.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "DTTR_COMPONENTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "mingw32-nix",
      "configurePreset": "mingw32-nix"
    }
  ]
}
